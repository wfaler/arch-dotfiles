{
    "label" : "lock",
    "action" : "hyprlock & sleep 0.5 && hyprctl dispatch dpms off",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend && hyprlock",
    "text" : "Sleep",
    "keybind" : "s"
}

{
    "label" : "logout",
    "action" : "hyprctl dispatch exit",
    "text" : "Exit",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "poweroff",
    "text" : "Shutdown",
    "keybind" : "p"
}
{
    "label" : "reboot",
    "action" : "reboot",
    "text" : "Reboot",
    "keybind" : "r"
}

